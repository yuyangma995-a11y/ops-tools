{
  "name": "yuziyuan-ops-installer",
  "version": "2.0.0",
  "description": "渔之源运营助手 Windows 安装包构建配置",
  "main": "installer.js",
  "scripts": {
    "build:win": "npx pkg . --target node18-win-x64 --output dist/yuziyuan-ops-installer-v2.0.0.exe --compress GZip",
    "build:all": "npx pkg . --targets node18-win-x64,node18-macos-x64,node18-macos-arm64 --output dist/yuziyuan-ops-installer --compress GZip"
  },
  "pkg": {
    "scripts": ["installer.js"],
    "targets": ["node18-win-x64"]
  },
  "dependencies": {}
}
